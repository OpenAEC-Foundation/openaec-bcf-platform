# === Development (local) ===
DATABASE_URL=postgres://bcf:bcf_dev_password@localhost:5432/bcf_platform
HOST=0.0.0.0
PORT=3000
RUST_LOG=bcf_server=debug,tower_http=debug
STORAGE_PATH=./data/snapshots

# === Production (docker-compose.prod.yml) ===
# Only POSTGRES_PASSWORD is needed — other vars are set in docker-compose.prod.yml
# POSTGRES_PASSWORD=<generated-by-deploy-script>

